{
  "name": "@you/review",
  "id": "builtin-review",
  "invocationSignature": {
    "parameters": [
      {
        "name": "input",
        "description": "Work request that must be independently reviewed before it is returned.",
        "required": true,
        "bindings": [
          {"kind": "POSITIONAL", "position": 1},
          {"kind": "STDIN"}
        ]
      }
    ]
  },
  "examples": [
    {"name": "positional-input", "description": {"type": "LOCALIZABLE_ASSET", "value": "Review draft release notes."}, "args": {"input": "Draft the release notes"}}
  ],
  "invocationReturn": {
    "policy": "EXPLICIT",
    "workTypeName": "reviewable-work",
    "terminalState": "approved"
  },
  "workTypes": [
    {
      "name": "reviewable-work",
      "handlingBehavior": ["DEFAULT"],
      "states": [
        {"name": "init", "type": "INITIAL"},
        {"name": "in-review", "type": "PROCESSING"},
        {"name": "approved", "type": "TERMINAL"},
        {"name": "failed", "type": "FAILED"}
      ]
    }
  ],
  "workers": [
    {"name": "review-work-executor", "type": "AGENT_WORKER", "promptFile": "prompts/executor.md"},
    {"name": "review-work-reviewer", "type": "AGENT_WORKER", "promptFile": "prompts/reviewer.md"}
  ],
  "workstations": [
    {
      "name": "execute-review-work",
      "type": "AGENT_RUN",
      "worker": "review-work-executor",
      "workPropagation": {"mode": "PRESERVE_INPUT"},
      "inputs": [{"workType": "reviewable-work", "state": "init"}],
      "outputs": [{"workType": "reviewable-work", "state": "in-review"}],
      "onFailure": [{"workType": "reviewable-work", "state": "failed"}],
      "promptFile": "prompts/executor.md"
    },
    {
      "name": "review-review-work",
      "type": "AGENT_RUN",
      "worker": "review-work-reviewer",
      "outcomeFormat": "decision-envelope",
      "inputs": [{"workType": "reviewable-work", "state": "in-review"}],
      "outputs": [{"workType": "reviewable-work", "state": "approved"}],
      "onRejection": [{"workType": "reviewable-work", "state": "init"}],
      "onFailure": [{"workType": "reviewable-work", "state": "failed"}],
      "promptFile": "prompts/reviewer.md"
    }
  ]
}
