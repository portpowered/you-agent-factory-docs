{
  "name": "@you/subagent",
  "id": "builtin-subagent",
  "invocationSignature": {
    "parameters": [
      {
        "name": "input",
        "description": "Text request for the one-pass subagent.",
        "required": true,
        "bindings": [
          {"kind": "POSITIONAL", "position": 1},
          {"kind": "STDIN"}
        ]
      }
    ]
  },
  "examples": [
    {
      "name": "positional-input",
      "description": {"type": "LOCALIZABLE_ASSET", "value": "Summarize a release request."},
      "args": {"input": "Summarize this release"}
    },
    {
      "name": "stdin-input",
      "description": {"type": "LOCALIZABLE_ASSET", "value": "Summarize the same request using structured input."},
      "args": {"input": "Summarize this release"}
    }
  ],
  "workTypes": [
    {
      "name": "task",
      "handlingBehavior": ["DEFAULT"],
      "states": [
        {"name": "init", "type": "INITIAL"},
        {"name": "complete", "type": "TERMINAL"},
        {"name": "failed", "type": "FAILED"}
      ]
    }
  ],
  "resources": [],
  "workers": [
    {
      "name": "subagent-worker",
      "type": "AGENT_WORKER",
      "agentTools": {
        "policy": "READ_ONLY"
      },
      "promptFile": "prompts/worker.md"
    }
  ],
  "workstations": [
    {
      "name": "run-subagent",
      "type": "AGENT_RUN",
      "worker": "subagent-worker",
      "inputs": [
        {"workType": "task", "state": "init"}
      ],
      "outputs": [
        {"workType": "task", "state": "complete"}
      ],
      "onFailure": [
        {"workType": "task", "state": "failed"}
      ],
      "promptFile": "prompts/run-subagent.md"
    }
  ]
}
